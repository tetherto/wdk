{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "./types",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "maxNodeModuleJsDepth": 1
  },
  "include": [
    "index.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "types",
    "bin"
  ]
}
