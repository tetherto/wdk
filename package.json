{
  "name": "@tetherto/wdk",
  "version": "1.0.0-beta.7",
  "description": "A flexible manager that can register and manage multiple wallet instances for different blockchains dynamically.",
  "keywords": [
    "wdk",
    "core"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/wdk.git"
  },
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@reown/walletkit": "^1.5.5",
    "@walletconnect/pay": "^1.0.8",
    "@tetherto/wdk-wallet": "^1.0.0-beta.6",
    "@walletconnect/utils": "^2.23.9",
    "bare-node-runtime": "^1.1.4"
  },
  "devDependencies": {
    "@walletconnect/sign-client": "^2.23.9",
    "cross-env": "7.0.3",
    "dotenv": "^17.4.2",
    "jest": "30.1.3",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
