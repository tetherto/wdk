{
  "name": "@tetherto/wdk-mcp",
  "version": "1.0.0-beta.1",
  "description": "MCP (Model Context Protocol) server for Tether WDK - enables AI agents to interact with multi-chain wallets",
  "type": "module",
  "main": "index.js",
  "bin": {
    "wdk-mcp": "./bin/wdk-mcp.js"
  },
  "scripts": {
    "start": "node bin/wdk-mcp.js",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "build:types": "tsc",
    "inspect": "npx @modelcontextprotocol/inspector node bin/wdk-mcp.js"
  },
  "keywords": [
    "tether",
    "usdt",
    "wdk",
    "wallet",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "claude",
    "llm",
    "multi-chain",
    "bitcoin",
    "ethereum",
    "solana",
    "ton"
  ],
  "author": "Tether Operations Limited",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/wdk-core.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/tetherto/wdk-core/issues"
  },
  "homepage": "https://docs.wallet.tether.io",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@tetherto/wdk": "^1.0.0-beta.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "standard": "^17.1.2",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@tetherto/wdk-wallet-evm": ">=1.0.0-beta.1",
    "@tetherto/wdk-wallet-btc": ">=1.0.0-beta.1",
    "@tetherto/wdk-wallet-ton": ">=1.0.0-beta.1",
    "@tetherto/wdk-wallet-solana": ">=1.0.0-beta.1",
    "@tetherto/wdk-wallet-tron": ">=1.0.0-beta.1"
  },
  "peerDependenciesMeta": {
    "@tetherto/wdk-wallet-evm": {
      "optional": true
    },
    "@tetherto/wdk-wallet-btc": {
      "optional": true
    },
    "@tetherto/wdk-wallet-ton": {
      "optional": true
    },
    "@tetherto/wdk-wallet-solana": {
      "optional": true
    },
    "@tetherto/wdk-wallet-tron": {
      "optional": true
    }
  },
  "files": [
    "index.js",
    "bin/",
    "src/",
    "types/",
    "AGENTS.md",
    "README.md"
  ],
  "standard": {
    "ignore": [
      "types/"
    ]
  }
}
